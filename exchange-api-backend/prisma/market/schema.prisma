generator client {
    provider = "prisma-client"
    output   = "../generated/market-client"
}

datasource db {
    provider = "postgresql"
}

model KLine {
    id          String   @id @default(uuid())
    symbol      String
    open        String
    close       String
    high        String
    low         String
    volume      String
    quoteVolume String
    trades      String
    start       DateTime
    end         DateTime

    @@unique([symbol, start])
    @@index([symbol, start])
}
